Panels:
  - Class: rviz_common/Displays
    Help Height: 0
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Common1
        - /Common1/TF1/Frames1
        - /PX031
        - /PX031/Planning1
        - /PX031/Planning1/PX03 DGP path1/Topic1
        - /PX031/Planning1/PX03 Poly for Safe Trajs1/Topic1
        - /PX031/Mapping1
        - /PX031/Mapping1/PX03 Lidar PointCloud1
        - /PX031/Mapping1/PX03 Lidar PointCloud1/Autocompute Value Bounds1
        - /PX031/Mapping1/PX03 Static Grid1/Topic1
        - /PX031/Mapping1/PX03 Heat Cloud1
        - /PX031/Others1
        - /PX03 Lidar PointCloud1
        - /PX03 Lidar PointCloud1/Autocompute Value Bounds1
      Splitter Ratio: 0.5
    Tree Height: 1157
  - Class: rviz_common/Selection
    Name: Selection
  - Class: rviz_common/Tool Properties
    Expanded:
      - /2D Goal Pose1
      - /Publish Point1
    Name: Tool Properties
    Splitter Ratio: 0.5886790156364441
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz_common/Time
    Experimental: false
    Name: Time
    SyncMode: 0
    SyncSource: PX03 Lidar PointCloud
